---
import BaseLayout from '../../layouts/BaseLayout.astro'
import WaterHardnessChecker from '../../components/WaterHardnessChecker.astro'
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro'
---

<BaseLayout title="UK Water Hardness Checker for Natural Hair — NaturalCurly">

  <section class="bg-cream px-6 pt-16 pb-10 md:pt-20 md:pb-12">
    <div class="max-w-hub mx-auto">

      <p class="font-sans text-xs uppercase tracking-wider text-taupe mb-4">
        Tools
      </p>

      <h1 class="mb-4"
          style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(2rem,5vw,3.25rem);font-weight:400;letter-spacing:-0.02em;line-height:1.1;font-variation-settings:'opsz' 36,'SOFT' 20;">
        UK Water Hardness Checker
      </h1>

      <p class="mb-10 max-w-prose"
         style="font-family:'Newsreader',Georgia,serif;font-style:italic;font-size:clamp(1.1rem,2vw,1.375rem);color:#6E6056;line-height:1.4;">
        Enter your postcode to find out whether hard water is affecting your curls — and what to do about it.
      </p>

      <WaterHardnessChecker />

    </div>
  </section>

  <section class="bg-cream border-t border-line px-6 py-12 md:py-16">
    <div class="max-w-prose mx-auto">

      <h2 class="mb-4"
          style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(1.375rem,2.5vw,1.75rem);font-weight:400;letter-spacing:-0.018em;line-height:1.2;font-variation-settings:'opsz' 20,'SOFT' 10;">
        Why it matters for curly hair
      </h2>

      <p class="font-sans text-base text-ink mb-4 leading-relaxed">
        Hard water contains dissolved calcium and magnesium minerals. These coat your hair shaft, blocking moisture from getting in and product from absorbing properly. If you're in London, the South East, or the East Midlands and your products seem to have stopped working — this is almost certainly why.
      </p>

      <p class="font-sans text-base text-ink mb-4 leading-relaxed">
        The fix is a chelating shampoo, which uses a different type of cleansing agent designed specifically to bond with mineral deposits and remove them. A regular clarifying shampoo won't do this.
      </p>

      <p class="font-sans text-base text-ink mb-8 leading-relaxed">
        <a href="/hair-care/hard-water-curly-hair-uk/"
           class="text-berry visited:text-berry hover:text-berry-dark transition-colors duration-150 no-underline">
          Read the full guide to hard water and curly hair →
        </a>
      </p>

      <AffiliateDisclosure />

    </div>
  </section>

</BaseLayout>
