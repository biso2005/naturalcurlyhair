---
import { getCollection } from 'astro:content'
import HubLanding from '../../components/HubLanding.astro'

export async function getStaticPaths() {
  const allHubs     = await getCollection('hubs')
  const allArticles = await getCollection('articles', ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true
  )

  return allHubs.map(hub => {
    const articles = allArticles
      .filter(a => a.data.hub === hub.data.hub)
      .sort((a, b) => b.data.published.localeCompare(a.data.published))
    return {
      params: { hub: hub.id },
      props:  { hub, articles },
    }
  })
}

const { hub, articles } = Astro.props
---

<HubLanding hub={hub} articles={articles} />
