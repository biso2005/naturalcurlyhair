---
import '../styles/fonts.css'
import '../styles/global.css'
import HubNavigation from '../components/HubNavigation.astro'

interface Props {
  title?: string
}
const { title } = Astro.props

const curlFamilies = [
  { label: 'Waves', types: [{ label: '2A', href: '/2a/' }, { label: '2B', href: '/2b/' }, { label: '2C', href: '/2c/' }] },
  { label: 'Curls', types: [{ label: '3A', href: '/3a/' }, { label: '3B', href: '/3b/' }, { label: '3C', href: '/3c/' }] },
  { label: 'Coils', types: [{ label: '4A', href: '/4a/' }, { label: '4B', href: '/4b/' }, { label: '4C', href: '/4c/' }] },
]

const footerColumns = [
  {
    heading: 'Explore',
    links: [
      { label: 'Hair care',  href: '/hair-care/' },
      { label: 'Reviews',    href: '/reviews/' },
      { label: 'Parents',    href: '/parents/' },
    ],
  },
  {
    heading: 'About',
    links: [
      { label: 'FAQs',    href: '/faqs/' },
      { label: 'Contact', href: '/contact/' },
    ],
  },
  {
    heading: 'Policies',
    links: [
      { label: 'Affiliate disclosure', href: '/affiliate-disclosure/' },
      { label: 'Privacy',              href: '/privacy/' },
      { label: 'Cookies',              href: '/cookies/' },
    ],
  },
]
---
<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title ?? 'naturalcurlyhair'}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preload" href="/fonts/Fraunces-Variable.woff2"
        as="font" type="font/woff2" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap"
        rel="stylesheet">
</head>
<body class="bg-cream text-ink font-sans">

  <HubNavigation />

  <main>
    <slot />
  </main>

  <footer class="bg-plum">
    <div class="max-w-hub mx-auto px-6 py-16">

      <a href="/" class="wordmark mb-12 leading-none block" aria-label="NaturalCurly home">
        <span class="wordmark-natural">Natural</span><span class="wordmark-curly">Curly</span>
      </a>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-16">

        <!-- By curl type — grouped by family -->
        <div>
          <p class="font-mono text-xs tracking-wider uppercase text-cream/45 mb-4">
            By curl type
          </p>
          <div class="flex flex-col" style="gap:10px;">
            {curlFamilies.map(family => (
              <div>
                <p class="font-sans mb-1" style="font-size:10px;color:#6E6056;">{family.label}</p>
                <p class="font-sans" style="font-size:0.875rem;">
                  {family.types.map((t, i) => (
                    <>
                      <a
                        href={t.href}
                        class="text-cream/75 visited:text-cream/75 hover:text-cream transition-colors duration-150 no-underline"
                      >{t.label}</a>
                      {i < family.types.length - 1 && (
                        <span class="text-cream/30" style="margin:0 5px;">·</span>
                      )}
                    </>
                  ))}
                </p>
              </div>
            ))}
          </div>
        </div>

        <!-- Remaining columns — generic -->
        {footerColumns.map(col => (
          <div>
            <p class="font-mono text-xs tracking-wider uppercase text-cream/45 mb-4">
              {col.heading}
            </p>
            <ul class="list-none m-0 p-0 flex flex-col gap-3">
              {col.links.map(link => (
                <li>
                  <a href={link.href}
                     class="font-sans text-sm text-cream/75 visited:text-cream/75 hover:text-cream transition-colors duration-150 no-underline">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}

      </div>

      <p class="font-sans text-xs text-cream/45 border-t border-cream/10 pt-8">
        © 2026 naturalcurlyhair editorial
      </p>

    </div>
  </footer>

</body>
</html>
