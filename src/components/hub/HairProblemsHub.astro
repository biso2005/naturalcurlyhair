---
import hairProblemsData from '../../data/hub_copy.json'

const { sections, catchall } = hairProblemsData.hair_problems

const sectionGradients = [
  'linear-gradient(160deg, #553D62 0%, #2C1D17 100%)',
  'linear-gradient(160deg, #3E2230 0%, #2C1D17 100%)',
  'linear-gradient(160deg, #4E7176 0%, #2C1D17 100%)',
  'linear-gradient(160deg, #A57256 0%, #3E2230 100%)',
  'linear-gradient(160deg, #6E6056 0%, #2C1D17 100%)',
]
---

<div class="max-w-hub mx-auto px-6">
  {sections.map((section, i) => (
    <section
      class="py-12 md:py-16"
      style={i > 0 ? 'border-top: 1px solid rgba(44,29,23,0.14);' : ''}
    >
      <div class="grid grid-cols-1 md:grid-cols-5 gap-8 lg:gap-12 items-start">
        <!-- Image block -->
        <div class="md:col-span-2 order-1">
          <div class="relative overflow-hidden rounded-sm" style="padding-top: 125%; position: relative;">
            <!-- Gradient fallback -->
            <div
              class="absolute inset-0"
              style={`background: ${sectionGradients[i]}; z-index: 0;`}
            ></div>
            <!-- Photo -->
            {section.image_path && (
              <img
                src={section.image_path}
                alt=""
                role="presentation"
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
                onerror="this.style.display='none'"
                style="z-index: 1;"
              />
            )}
            <!-- Spiral mark -->
            <div class="absolute top-2 right-2 pointer-events-none" style="z-index: 2;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <circle cx="7" cy="7" r="6" stroke="white" stroke-opacity="0.4" stroke-width="1" fill="none" />
                <circle cx="7" cy="7" r="3" stroke="white" stroke-opacity="0.4" stroke-width="1" fill="none" />
              </svg>
            </div>
            <!-- Image kicker -->
            <p
              class="absolute bottom-2 left-2 font-sans uppercase"
              style="font-size: 9px; color: #F8F3EA; letter-spacing: 0.10em; z-index: 2; line-height: 1;"
            >{section.image_kicker}</p>
          </div>
        </div>

        <!-- Text block -->
        <div class="md:col-span-3 order-2">
          <!-- Framing label -->
          <p
            class="font-sans uppercase mb-2"
            style="font-size: 10px; color: #A2384B; letter-spacing: 0.10em;"
          >{section.number} — {section.framing_label}</p>

          <!-- Section title -->
          <h2
            class="mb-3"
            style="font-family: 'Fraunces Variable', Georgia, serif; font-size: clamp(1.125rem, 2vw, 1.375rem); font-weight: 400; font-variation-settings: 'opsz' 22, 'SOFT' 10; color: #2C1D17; line-height: 1.25;"
          >{section.title}</h2>

          <!-- Body -->
          <p
            class="mb-5"
            style="font-family: 'Newsreader', Georgia, serif; font-size: 0.875rem; color: #2C1D17; line-height: 1.55;"
          >{section.body}</p>

          <!-- Related articles -->
          {section.related_articles.length > 0 && (
            <ul style="list-style: none; margin: 0; padding: 0;">
              {section.related_articles.map((article) => (
                <li
                  class="flex items-baseline gap-3 py-2"
                  style="border-top: 1px solid rgba(44,29,23,0.14);"
                >
                  {article.tag && (
                    <span
                      class="font-sans uppercase flex-shrink-0"
                      style="font-size: 8px; color: #6E6056; letter-spacing: 0.08em; border: 1px solid rgba(44,29,23,0.14); border-radius: 2px; padding: 2px 6px;"
                    >{article.tag}</span>
                  )}
                  <a
                    href={article.href}
                    class="no-underline visited:text-berry"
                    style="font-family: 'Newsreader', Georgia, serif; font-size: 0.8125rem; color: #2C1D17; line-height: 1.35; flex: 1; transition: color 150ms;"
                    onmouseover="this.style.color='#A2384B'"
                    onmouseout="this.style.color='#2C1D17'"
                  >{article.title}</a>
                  <span style="font-size: 11px; color: #A2384B; flex-shrink: 0;" aria-hidden="true">→</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </section>
  ))}

  <!-- Catchall CTA -->
  <div class="pb-8" style="border-top: 1px solid rgba(44,29,23,0.14); padding-top: 2.5rem;">
    <p
      class="font-sans uppercase mb-2"
      style="font-size: 10px; color: #A2384B; letter-spacing: 0.10em;"
    >{catchall.kicker}</p>
    <p
      class="mb-4"
      style="font-family: 'Newsreader', Georgia, serif; font-size: 0.875rem; color: #6E6056; line-height: 1.55;"
    >{catchall.body}</p>
    <a
      href={catchall.cta_href}
      class="font-sans visited:text-berry"
      style="font-size: 11px; color: #A2384B; text-decoration: none;"
      onmouseover="this.style.textDecoration='underline'"
      onmouseout="this.style.textDecoration='none'"
    >{catchall.cta}</a>
  </div>
</div>
