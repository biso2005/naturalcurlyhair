---
interface Props {
  copy: {
    kicker: string
    body: string
    cta: string
    cta_href: string
  }
}

const { copy } = Astro.props
---

<div
  class="w-full md:relative sticky top-0 z-30"
  style="background:#F1E8D9;"
>
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 md:gap-6 px-6 md:px-10 py-5 md:py-6 max-w-hub mx-auto">
    <div>
      <p
        class="font-sans uppercase mb-1"
        style="font-size:11px;letter-spacing:0.10em;color:#6E6056;"
      >{copy.kicker}</p>
      <p
        style="font-family:'Newsreader',Georgia,serif;font-size:0.875rem;color:#2C1D17;line-height:1.55;"
      >{copy.body}</p>
    </div>
    <a
      href={copy.cta_href}
      class="block md:inline-block text-center font-sans whitespace-nowrap visited:text-cream"
      style="font-size:11px;letter-spacing:0.06em;background:#3E2230;color:#F8F3EA;padding:10px 16px;border-radius:2px;text-decoration:none;"
    >{copy.cta}</a>
  </div>
</div>
