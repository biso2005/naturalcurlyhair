// ─── LOOKUP ──────────────────────────────────────────────────────────────────

function extractDistrict(postcode) {
  const clean = postcode.trim().toUpperCase().replace(/\s+/g, '');
  for (let len = 5; len >= 1; len--) {
    const candidate = clean.slice(0, len);
    if (DISTRICTS[candidate]) return candidate;
  }
  return null;
}

function lookup(postcode) {
  const district = extractDistrict(postcode);
  if (!district) return null;
  return { district, ...DISTRICTS[district] };
}

// ─── RENDER ───────────────────────────────────────────────────────────────────

function barHtml(mg_l) {
  const max = 400;
  const pct = Math.min((mg_l / max) * 100, 100).toFixed(1);
  const color = mg_l < 100 ? '#4A9B6F' : mg_l < 150 ? '#7AB648' : mg_l < 200 ? '#E8A020' : mg_l < 300 ? '#D4621A' : '#A2384B';
  return `<div style="margin:16px 0;">
    <div style="height:8px;background:#E8E0D8;border-radius:4px;overflow:hidden;">
      <div style="height:100%;width:${pct}%;background:${color};border-radius:4px;"></div>
    </div>
    <div style="display:flex;justify-content:space-between;margin-top:4px;font-size:11px;color:#6E6056;font-family:'Public Sans',system-ui,sans-serif;">
      <span>Soft</span><span>Moderately Hard</span><span>Very Hard</span>
    </div>
  </div>`;
}

function resultHtml(result) {
  const cls = CLASSIFICATION[result.level];
  return `<div style="margin-top:24px;border:2px solid ${cls.color};border-radius:8px;overflow:hidden;font-family:'Public Sans',system-ui,sans-serif;">
    <div style="background:${cls.color};padding:16px 20px;display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;">
      <span style="font-family:'Fraunces Variable','Fraunces',Georgia,serif;font-style:italic;font-size:28px;color:#fff;line-height:1;font-variation-settings:'opsz' 20,'SOFT' 10;">${cls.label}</span>
      <span style="color:rgba(255,255,255,0.85);font-size:14px;">${result.mg_l} mg/L · ${result.city}</span>
    </div>
    <div style="padding:16px 20px 0;background:${cls.bg};">${barHtml(result.mg_l)}</div>
    <div style="padding:16px 20px;background:${cls.bg};color:#2C1D17;font-size:15px;line-height:1.65;">${cls.advice}</div>
    <div style="padding:12px 20px;background:#fff;border-top:1px solid rgba(44,29,23,0.1);display:flex;gap:32px;flex-wrap:wrap;">
      <div>
        <div style="font-size:11px;text-transform:uppercase;letter-spacing:0.08em;color:#6E6056;margin-bottom:2px;">Chelating schedule</div>
        <div style="font-size:14px;font-weight:600;color:#2C1D17;">${cls.chelate}</div>
      </div>
      <div>
        <div style="font-size:11px;text-transform:uppercase;letter-spacing:0.08em;color:#6E6056;margin-bottom:2px;">Water supplier</div>
        <div style="font-size:14px;color:#2C1D17;">${result.supplier}</div>
      </div>
      <div>
        <div style="font-size:11px;text-transform:uppercase;letter-spacing:0.08em;color:#6E6056;margin-bottom:2px;">Range</div>
        <div style="font-size:14px;color:#2C1D17;">${cls.range}</div>
      </div>
    </div>
    <div style="padding:12px 20px;background:#fff;border-top:1px solid rgba(44,29,23,0.1);font-size:13px;color:#6E6056;">
      Data: TapWater.uk + Drinking Water Inspectorate · district-level approximates ·
      <a href="/hair-care/hard-water-curly-hair-uk/" style="color:#A2384B;text-decoration:none;">Is hard water wrecking your curls? →</a>
    </div>
  </div>`;
}

function errorHtml(msg) {
  return `<div style="margin-top:16px;padding:14px 16px;background:#fff;border:1px solid rgba(44,29,23,0.14);border-radius:6px;font-size:14px;color:#6E6056;line-height:1.6;font-family:'Public Sans',system-ui,sans-serif;">
    ${msg} <a href="https://tapwater.uk" target="_blank" rel="noopener noreferrer" style="color:#A2384B;text-decoration:none;">Check TapWater.uk →</a>
  </div>`;
}

// ─── WIRE UP ─────────────────────────────────────────────────────────────────

const input = document.getElementById('whc-input');
const btn   = document.getElementById('whc-btn');
const out   = document.getElementById('whc-result');

function check() {
  const val = input.value;
  if (!val.trim()) {
    out.innerHTML = errorHtml('Enter a postcode or district to check.');
    return;
  }
  const result = lookup(val);
  if (result) {
    out.innerHTML = resultHtml(result);
  } else {
    out.innerHTML = errorHtml("We don't have data for that postcode yet. Try entering just the district (e.g. SW2 rather than SW2 1AA). For a definitive reading, check your supplier's website directly — every major UK supplier publishes hardness by postcode.");
  }
}

btn.addEventListener('click', check);
input.addEventListener('keydown', e => { if (e.key === 'Enter') check(); });
</script>
