---
// No props needed — purely client-side interactive
---

<div id="whc-root" style="font-family:'Public Sans',system-ui,-apple-system,sans-serif;background:#F8F3EA;border:1px solid rgba(44,29,23,0.14);border-radius:8px;padding:24px 24px 20px;max-width:600px;">

  <p style="font-size:11px;text-transform:uppercase;letter-spacing:0.08em;color:#6E6056;margin:0 0 8px;">
    UK Water Hardness Checker
  </p>

  <p id="whc-heading" style="font-family:'Fraunces Variable','Fraunces',Georgia,serif;font-style:italic;font-size:clamp(1.25rem,3vw,1.625rem);font-variation-settings:'opsz' 20,'SOFT' 10;color:#2C1D17;margin:0 0 16px;line-height:1.2;">
    What's in your water?
  </p>

  <div style="display:flex;gap:8px;flex-wrap:wrap;">
    <input
      id="whc-input"
      type="text"
      placeholder="e.g. SW2 or SW2 1AA"
      aria-label="Postcode or postcode district"
      style="font-family:'Public Sans',system-ui,sans-serif;font-size:15px;color:#2C1D17;background:#fff;border:1px solid rgba(44,29,23,0.28);border-radius:4px;padding:10px 14px;flex:1 1 180px;outline:none;"
    />
    <button
      id="whc-btn"
      style="font-family:'Public Sans',system-ui,sans-serif;font-size:14px;font-weight:600;background:#A2384B;color:#fff;border:none;border-radius:4px;padding:10px 20px;cursor:pointer;white-space:nowrap;"
    >
      Check
    </button>
  </div>

  <div id="whc-result" style="margin-top:0;"></div>

  <p style="margin-top:16px;font-size:12px;color:#6E6056;line-height:1.5;">
    Figures are district-level approximates based on supplier data and the Drinking Water Inspectorate. Hardness can vary within a district depending on your specific supply zone.
  </p>

</div>

