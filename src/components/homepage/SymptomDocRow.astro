---
interface Card {
  img_kicker: string
  img_description: string
  href: string
}

interface Props {
  copy: {
    section_title: string
    cards: Card[]
  }
}

const { copy } = Astro.props

const imageSrcs = [
  '/images/placeholders/symptom-1.webp',
  '/images/placeholders/symptom-2.webp',
  '/images/placeholders/symptom-3.webp',
  '/images/placeholders/symptom-4.webp',
]

const fallbackGradients = [
  'linear-gradient(160deg, #4A3228 0%, #2C1D17 100%)',
  'linear-gradient(160deg, #4E6B70 0%, #2E4447 100%)',
  'linear-gradient(160deg, #8C6A58 0%, #5C3D2E 100%)',
  'linear-gradient(160deg, #9C8070 0%, #6E5848 100%)',
]
---

<section class="bg-cream border-t border-line px-6 pt-12 pb-10">
  <div class="max-w-hub mx-auto">

    <h2
      class="text-ink mb-8"
      style="font-family:'Fraunces Variable',Georgia,serif;font-size:18px;font-weight:400;letter-spacing:-0.012em;line-height:1.2;font-variation-settings:'opsz' 18,'SOFT' 10;"
    >
      {copy.section_title}
    </h2>

    <!-- Desktop: 4-column / Mobile: 2×2 -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-[10px] md:gap-[10px]">
      {copy.cards.map((card, i) => (
        <a href={card.href} class="no-underline group">

          <!-- 1:1 image tile with caption overlaid -->
          <div
            class="relative overflow-hidden"
            style={`border-radius:2px;padding-top:100%;background:${fallbackGradients[i % fallbackGradients.length]};`}
          >
            <img
              src={imageSrcs[i % imageSrcs.length]}
              alt=""
              aria-hidden="true"
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
              decoding="async"
              onerror={`this.style.display='none'`}
            />

            <!-- Bottom gradient overlay -->
            <div
              class="absolute inset-0"
              style="background:linear-gradient(to top, rgba(44,29,23,0.85) 0%, rgba(44,29,23,0) 50%);"
            />

            <!-- Spiral mark top-right -->
            <svg
              class="absolute top-2 right-2"
              width="14" height="14" viewBox="0 0 14 14"
              fill="none" aria-hidden="true"
            >
              <circle cx="7" cy="7" r="6" stroke="white" stroke-width="1" stroke-opacity="0.4" />
              <circle cx="7" cy="7" r="3" stroke="white" stroke-width="1" stroke-opacity="0.4" />
            </svg>

            <!-- Caption block -->
            <div class="absolute bottom-0 left-0 px-3 pb-3">
              <p class="font-sans uppercase" style="font-size:9px;letter-spacing:0.10em;color:rgba(248,243,234,0.75);line-height:1;margin-bottom:3px;">
                {card.img_kicker}
              </p>
              <p style="font-family:'Newsreader',Georgia,serif;font-size:11px;color:#F8F3EA;line-height:1.3;">
                {card.img_description}
              </p>
            </div>
          </div>

        </a>
      ))}
    </div>

  </div>
</section>
