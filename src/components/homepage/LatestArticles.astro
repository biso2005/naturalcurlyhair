---
import type { ArticleSummary } from '../../lib/latestArticles'

interface Props {
  copy: {
    kicker: string
    headline: string
    meta: string
    all_articles_cta: string
  }
  articles: ArticleSummary[]
}

const { copy, articles } = Astro.props

function formatDate(iso: string): string {
  const d = new Date(iso)
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
}
---

<section class="bg-cream-2 border-t border-line px-6 pt-12 pb-10">
  <div class="max-w-hub mx-auto">

    <p class="font-sans text-berry uppercase mb-2" style="font-size:11px;letter-spacing:0.10em;">
      {copy.kicker}
    </p>
    <h2
      class="text-ink mb-1"
      style="font-family:'Fraunces Variable',Georgia,serif;font-size:24px;font-weight:400;letter-spacing:-0.018em;line-height:1.15;font-variation-settings:'opsz' 24,'SOFT' 10;"
    >
      {copy.headline}
    </h2>
    <p class="font-sans text-taupe mb-8" style="font-size:12px;">
      {copy.meta}
    </p>

    <ol class="list-none m-0 p-0">
      {articles.map(article => (
        <li class="border-t border-line py-4">
          <a href={article.href} class="no-underline group flex items-center gap-4">

            <!-- Thumbnail: 50px mobile, 60px desktop -->
            <div
              class="flex-shrink-0 overflow-hidden flex items-center justify-center"
              style="width:50px;height:50px;border-radius:2px;background:#6E6056;"
            >
              {article.heroImage ? (
                <img
                  src={article.heroImage}
                  alt=""
                  aria-hidden="true"
                  class="w-full h-full object-cover"
                  loading="lazy"
                  decoding="async"
                  onerror="this.style.display='none'"
                />
              ) : (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="11" stroke="white" stroke-width="1" stroke-opacity="0.35" />
                  <circle cx="12" cy="12" r="5"  stroke="white" stroke-width="1" stroke-opacity="0.35" />
                </svg>
              )}
            </div>

            <!-- Row content -->
            <div class="flex-1 min-w-0 md:flex md:items-baseline md:justify-between md:gap-4">

              <div class="flex items-baseline gap-3 mb-1 md:mb-0 md:flex-shrink-0">
                <span class="font-sans text-taupe" style="font-size:12px;">
                  {formatDate(article.published)}
                </span>
                <span class="font-sans text-berry uppercase" style="font-size:11px;letter-spacing:0.10em;">
                  {article.hub.toUpperCase()}
                </span>
              </div>

              <span
                class="md:flex-1 md:truncate md:mx-3 group-hover:text-berry transition-colors duration-150 block"
                style="font-family:'Fraunces Variable',Georgia,serif;font-size:17px;font-weight:400;letter-spacing:-0.012em;line-height:1.35;font-variation-settings:'opsz' 18,'SOFT' 10;color:#2C1D17;"
              >
                {article.title}
              </span>

              <div class="flex items-baseline gap-3 mt-1 md:mt-0 md:flex-shrink-0">
                <span class="font-sans text-taupe" style="font-size:12px;">{article.readTime}</span>
                <span class="font-sans text-berry" style="font-size:12px;" aria-hidden="true">→</span>
              </div>

            </div>
          </a>
        </li>
      ))}
    </ol>

    <div class="border-t border-line pt-6 mt-2">
      <a
        href="/articles/"
        class="font-sans text-berry visited:text-berry hover:text-berry-dark transition-colors duration-150 no-underline"
        style="font-size:12px;"
      >
        {copy.all_articles_cta}
      </a>
    </div>

  </div>
</section>
