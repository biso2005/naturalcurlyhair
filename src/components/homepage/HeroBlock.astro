---
interface Props {
  copy: {
    kicker: string
    headline: string
    tagline: string
  }
}

const { copy } = Astro.props
---

<!-- Full-bleed hero: image fills width, text overlaid -->
<section class="relative w-full overflow-hidden" style="background:#2C1D17;">

  <div class="relative w-full" style="min-height:480px;">
    <img
      src="/images/placeholders/hero.webp"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      onerror="this.style.display='none'"
    />

    <!-- Desktop: left-third gradient -->
    <div
      class="hidden md:block absolute inset-0"
      style="background:linear-gradient(to right, rgba(62,34,48,0.85) 0%, rgba(62,34,48,0) 50%);"
    />

    <!-- Mobile: bottom-up gradient -->
    <div
      class="md:hidden absolute inset-0"
      style="background:linear-gradient(to top, rgba(62,34,48,0.90) 0%, rgba(62,34,48,0) 40%);"
    />

    <!-- Spiral mark, desktop only -->
    <svg
      class="hidden md:block absolute top-5 right-6"
      width="28" height="28" viewBox="0 0 28 28"
      fill="none" xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <circle cx="14" cy="14" r="13" stroke="white" stroke-width="1" stroke-opacity="0.4" />
      <circle cx="14" cy="14" r="6"  stroke="white" stroke-width="1" stroke-opacity="0.4" />
    </svg>

    <!-- Desktop: text, left-anchored, vertically centred -->
    <div
      class="hidden md:flex flex-col justify-center absolute inset-y-0 left-0 px-10 lg:px-16"
      style="max-width:440px;min-height:600px;"
    >
      <p class="font-sans uppercase mb-4" style="font-size:11px;letter-spacing:0.10em;color:rgba(248,243,234,0.70);">
        {copy.kicker}
      </p>
      <h1
        class="mb-4"
        style="font-family:'Fraunces Variable',Georgia,serif;font-size:34px;font-weight:400;letter-spacing:-0.022em;line-height:1.1;font-variation-settings:'opsz' 36,'SOFT' 20;color:#F8F3EA;"
      >
        {copy.headline}
      </h1>
      <p
        style="font-family:'Newsreader',Georgia,serif;font-style:italic;font-size:17px;line-height:1.45;color:rgba(248,243,234,0.85);"
      >
        {copy.tagline}
      </p>
    </div>

    <!-- Mobile: text anchored to bottom of image -->
    <div class="md:hidden absolute bottom-0 left-0 right-0 px-5 pb-6 pt-24">
      <p class="font-sans uppercase mb-3" style="font-size:11px;letter-spacing:0.10em;color:rgba(248,243,234,0.70);">
        {copy.kicker}
      </p>
      <h1
        class="mb-3"
        style="font-family:'Fraunces Variable',Georgia,serif;font-size:28px;font-weight:400;letter-spacing:-0.022em;line-height:1.1;font-variation-settings:'opsz' 30,'SOFT' 20;color:#F8F3EA;"
      >
        {copy.headline}
      </h1>
      <p style="font-family:'Newsreader',Georgia,serif;font-style:italic;font-size:15px;line-height:1.4;color:rgba(248,243,234,0.85);">
        {copy.tagline}
      </p>
    </div>
  </div>

</section>
