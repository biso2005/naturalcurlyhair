---
interface Card {
  title: string
  body: string
  faq_href: string
}

interface Props {
  copy: {
    section_title: string
    cards: Card[]
  }
}

const { copy } = Astro.props
---

<section class="border-t border-line px-6 pt-12 pb-10" style="background:#F1E8D9;">
  <div class="max-w-hub mx-auto">

    <h2
      class="text-ink mb-8"
      style="font-family:'Fraunces Variable',Georgia,serif;font-size:18px;font-weight:400;letter-spacing:-0.012em;line-height:1.2;font-variation-settings:'opsz' 18,'SOFT' 10;"
    >
      {copy.section_title}
    </h2>

    <!-- 3-column desktop / single-column mobile -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {copy.cards.map(card => (
        <a href={card.faq_href} class="no-underline group block" style="background:#F8F3EA;border-left:2px solid #A2384B;padding:14px;">
          <h3
            class="text-ink group-hover:text-berry transition-colors duration-150 mb-2"
            style="font-family:'Fraunces Variable',Georgia,serif;font-size:13px;font-weight:400;letter-spacing:-0.008em;line-height:1.3;font-variation-settings:'opsz' 14,'SOFT' 10;"
          >
            {card.title}
          </h3>
          <p
            class="text-taupe"
            style="font-family:'Newsreader',Georgia,serif;font-size:11px;line-height:1.5;"
          >
            {card.body}
          </p>
        </a>
      ))}
    </div>

  </div>
</section>
