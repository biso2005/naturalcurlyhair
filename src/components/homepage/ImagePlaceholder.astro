---
interface Props {
  aspectRatio: '4:5' | '1:1' | '3:2' | '16:9' | 'hero-full'
  texture?: 'dark-warm' | 'mid-warm' | 'cool' | 'warm-neutral' | 'deep-plum'
  src?: string
  tag?: string
  withSpiral?: boolean
  overlayText?: string
  overlayPosition?: 'bottom-left' | 'bottom-up' | 'left-third'
  class?: string
}

const {
  aspectRatio,
  texture = 'mid-warm',
  src,
  tag,
  withSpiral = false,
  overlayText,
  overlayPosition = 'bottom-left',
  class: className = '',
} = Astro.props

const paddingMap: Record<string, string> = {
  '4:5':       '125%',
  '1:1':       '100%',
  '3:2':       '66.667%',
  '16:9':      '56.25%',
  'hero-full': '42.5%',
}

const gradientMap: Record<string, string> = {
  'dark-warm':    'linear-gradient(160deg, #4A3228 0%, #2C1D17 100%)',
  'mid-warm':     'linear-gradient(160deg, #8C6A58 0%, #5C3D2E 100%)',
  'cool':         'linear-gradient(160deg, #4E6B70 0%, #2E4447 100%)',
  'warm-neutral': 'linear-gradient(160deg, #9C8070 0%, #6E5848 100%)',
  'deep-plum':    'linear-gradient(160deg, #6B3B52 0%, #3E2230 100%)',
}

const overlayGradientMap: Record<string, string> = {
  'bottom-left': 'linear-gradient(to top, rgba(44,29,23,0.75) 0%, rgba(44,29,23,0) 60%)',
  'bottom-up':   'linear-gradient(to top, rgba(62,34,48,0.9) 0%, rgba(62,34,48,0) 40%)',
  'left-third':  'linear-gradient(to right, rgba(62,34,48,0.85) 0%, rgba(62,34,48,0) 50%)',
}

const useImage = !!src
const needsOverlay = !!(overlayText || overlayPosition === 'left-third' || overlayPosition === 'bottom-up')
---

<div
  class={`relative overflow-hidden ${className}`}
  style="border-radius:2px;"
>
  <div
    style={`padding-top:${paddingMap[aspectRatio]};${useImage ? '' : `background:${gradientMap[texture]};`}`}
    aria-hidden="true"
  >
    {useImage && (
      <img
        src={src}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
        decoding="async"
        onerror={`this.style.display='none';this.parentElement.style.background='${gradientMap[texture]}'`}
      />
    )}

    {needsOverlay && (
      <div
        class="absolute inset-0"
        style={`background:${overlayGradientMap[overlayPosition]};`}
      />
    )}

    {overlayText && (
      <span
        class="absolute bottom-0 left-0 px-[14px] pb-[14px] font-sans text-cream/90 uppercase"
        style="font-size:11px;letter-spacing:0.10em;line-height:1;"
      >
        {overlayText}
      </span>
    )}

    {tag && !overlayText && (
      <span
        class="absolute bottom-3 left-3 font-sans text-cream/80 uppercase"
        style="font-size:11px;letter-spacing:0.10em;line-height:1;"
      >
        {tag}
      </span>
    )}

    {withSpiral && (
      <svg
        class="absolute top-3 right-3"
        width="26"
        height="26"
        viewBox="0 0 26 26"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <circle cx="13" cy="13" r="12" stroke="white" stroke-width="1" stroke-opacity="0.4" />
        <circle cx="13" cy="13" r="6"  stroke="white" stroke-width="1" stroke-opacity="0.4" />
      </svg>
    )}
  </div>
</div>
