---
import type { CollectionEntry } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import HubHero from './hub/HubHero.astro'
import SymptomDirectory from './hub/SymptomDirectory.astro'
import GroupedLibrary from './hub/GroupedLibrary.astro'
import FlatList from './hub/FlatList.astro'
import hubCopy from '../data/hub_copy.json'

interface Props {
  hub: CollectionEntry<'hubs'>
  articles: CollectionEntry<'articles'>[]
}

const { hub, articles } = Astro.props
const mode  = hub.data.mode ?? 'flat'
const hubId = hub.id
---

<BaseLayout title={`${hub.data.title} — naturalcurlyhair`}>
  <HubHero
    hubId={hubId}
    title={hub.data.title}
    dek={hub.data.dek}
    heroImage={hub.data.heroImage}
  />

  {mode === 'symptom-directory' && (
    <SymptomDirectory copy={hubCopy} />
  )}

  {mode === 'grouped' && (
    <GroupedLibrary
      articles={articles}
      groupBy={hub.data.groupBy ?? 'tag'}
      hubId={hubId}
      copy={hubCopy}
    />
  )}

  {(mode === 'flat' || !mode) && (
    <FlatList articles={articles} hubId={hubId} />
  )}
</BaseLayout>
